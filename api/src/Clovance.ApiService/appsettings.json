{
  "ConnectionStrings": {
    "clovance-database": "Host=localhost;Port=5432;Database=database;Username=postgres;Password=postgres"
  },
  "Identity": {
    "Invitations": {
      "ExpirationHours": 48
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "VERY_LONG_AND_SECRET_PASSWORD_OF_AT_LEAST_32_CHARACTERS",
    "Issuer": "Clovance.Api",
    "Audience": "Clovance.Client",
    "ExpirationMinutes": 60
  }
}
